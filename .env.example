# FAMLY-Office Environment Variables
# Copy this file to `.env` and fill in the required values.
# cp .env.example .env

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED FOR PRODUCTION
# These are checked at startup. The server will refuse to start without them.
# ═══════════════════════════════════════════════════════════════════════════════

# Server port (required in production)
PORT=3001

# Node environment: "development" | "production" | "test"
NODE_ENV=development

# Comma-separated list of allowed CORS origins.
# Leave empty in production to deny all cross-origin requests, or set to your frontend URL.
# Example: https://app.famlyoffice.com,https://admin.famlyoffice.com
CORS_ORIGINS=

# ═══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION — At least ONE is required for production deployment
# Both can be set simultaneously; JWT is tried first if Authorization header is present.
# ═══════════════════════════════════════════════════════════════════════════════

# API Key: clients authenticate via `X-API-Key` header.
# Generate a strong random key: openssl rand -hex 32
FAMLY_API_KEY=CHANGEME

# JWT Secret: used to sign/verify HS256 JWTs for Bearer auth.
# Generate a strong random secret: openssl rand -hex 64
FAMLY_JWT_SECRET=CHANGEME

# ═══════════════════════════════════════════════════════════════════════════════
# ENCRYPTION — Required for document vault encryption (AES-256-GCM)
# ═══════════════════════════════════════════════════════════════════════════════

# Encryption key for the document vault.
# Option A (recommended): 64-character hex string. Generate: openssl rand -hex 32
# Option B: A strong passphrase (will be derived via PBKDF2)
FAMLY_ENCRYPTION_KEY=CHANGEME

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — External Service Integration
# These enable additional features but are not required for core API operation.
# ═══════════════════════════════════════════════════════════════════════════════

# Brave Search API key for web search integration.
# Get yours at: https://brave.com/search/api/
BRAVE_SEARCH_KEY=

# ─── Cloud AI (for AI-powered features) ──────────────────────────────────────

# Cloud AI provider API key (or use OPENAI_API_KEY below).
# Supports OpenAI-compatible endpoints when CLOUD_AI_URL is set.
CLOUD_AI_KEY=CHANGEME

# OpenAI API key (alternative to CLOUD_AI_KEY). Used if CLOUD_AI_KEY is not set.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Custom cloud AI endpoint URL. Defaults to OpenAI if not set.
# Example: "https://api.anthropic.com/v1" or your OpenAI-compatible proxy.
CLOUD_AI_URL=

# Cloud AI model name. Default: "gpt-4o-mini"
CLOUD_AI_MODEL=gpt-4o-mini

# ─── Local LLM (Ollama or similar) ───────────────────────────────────────────

# Local LLM endpoint URL. Default: "http://localhost:11434/v1"
LOCAL_LLM_URL=http://localhost:11434/v1

# Local LLM model name. Default: "llama3.2"
LOCAL_LLM_MODEL=llama3.2

# ─── GitHub Integration ──────────────────────────────────────────────────────

# GitHub personal access token for research/PR features.
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Logging
# ═══════════════════════════════════════════════════════════════════════════════

# Log level: "fatal" | "error" | "warn" | "info" | "debug" | "trace" | "silent"
# Default: "info"
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════════════════════
# LOCAL DOCKER POSTGRESQL (Development)
# Copy these values when running the Docker Compose service (see README → Docker Setup).
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL connection string for local Docker instance
DATABASE_URL=postgresql://famly:famly_secret@localhost:5432/famly_office

# PostgreSQL credentials (must match docker-compose.yml environment)
POSTGRES_USER=famly
POSTGRES_PASSWORD=famly_secret
POSTGRES_DB=famly_office
