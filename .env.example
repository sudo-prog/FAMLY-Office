# ─────────────────────────────────────────────────────────────────
# FAMILY OFFICE — Environment Configuration
# ─────────────────────────────────────────────────────────────────

# ── AI Provider Configuration ──────────────────────────────────────
# Default: Gemini Web2API (local proxy at localhost:8081)
LLM_BASE_URL=http://localhost:8081/v1
LLM_API_KEY=gemini-web2api
LLM_MODEL=gemini-3.5-flash

# ── OpenRouter Fallback (optional) ────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_FALLBACK_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Production (Cloudflare Tunnel) ───────────────────────────────
# Expose gemini-web2api via Cloudflare Tunnel for production:
#   cloudflared tunnel run <your-tunnel-name>
# Then set:
# LLM_BASE_URL=https://<your-tunnel>.trycloudflare.com/v1

# ── Local LLM (Ollama / LM Studio) ──────────────────────────────
# Uncomment if using local LLM instead of cloud:
# LOCAL_LLM_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=llama3.2

# ── Cloud AI (alternative to gemini-web2api) ─────────────────────
# CLOUD_AI_KEY=sk-...
# CLOUD_AI_MODEL=gemini-3.5-flash
# CLOUD_AI_URL=http://localhost:8081/v1

# ── Vercel Deployment ────────────────────────────────────────────
# Set these in Vercel dashboard:
#   LLM_BASE_URL       → https://<your-tunnel>.trycloudflare.com/v1
#   OPENROUTER_API_KEY → sk-or-... (optional fallback)