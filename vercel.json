{
  "framework": "vite",
  "buildCommand": "pnpm --filter @workspace/family-office run build",
  "outputDirectory": "artifacts/family-office/dist",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "/api/[...path]?...path=$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/((?!api/).*)$",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
